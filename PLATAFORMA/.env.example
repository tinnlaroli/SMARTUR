# ── PLATAFORMA — Variables de entorno ───────────────────────────────────────
# Copia este archivo a .env y ajusta los valores para tu entorno.

# URL base de la API backend (sin trailing slash).
# En desarrollo local usa el proxy de Vite (/api/v2).
# En Docker/producción: URL completa con host y puerto.
VITE_API_URL=/api/v2

# URL del servicio de ML (motor de recomendaciones)
VITE_MODELO_URL=http://localhost:8000

# URL del sitio de la landing page (para links de retorno)
VITE_BUSINESS_URL=http://localhost:4321/
