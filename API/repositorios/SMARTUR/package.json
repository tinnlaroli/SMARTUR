{
  "name": "smartur-platform",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:dashboard": "vite --config vite.config.dashboard.js",
    "dev:all": "concurrently \"pnpm run dev\" \"pnpm run dev:dashboard\"",
    "build": "vite build",
    "build:dashboard": "vite build --config vite.config.dashboard.js",
    "preview": "vite preview",
    "start": "set HOST=0.0.0.0 && vite --host"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.14",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.4.18",
    "vite": "^7.0.2",
    "vite-plugin-pwa": "^1.2.0"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@heroicons/react": "^2.2.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^3.0.4",
    "@splinetool/runtime": "^1.12.61",
    "@tabler/icons-react": "^3.34.0",
    "@tailwindcss/vite": "^4.1.17",
    "aos": "^2.3.4",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "flubber": "^0.4.2",
    "framer-motion": "^12.23.3",
    "gsap": "^3.14.2",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.555.0",
    "motion": "^12.23.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.14.2",
    "swiper": "^12.1.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animated": "^2.0.0",
    "three": "^0.183.1"
  }
}
