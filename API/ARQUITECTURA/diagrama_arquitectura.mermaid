%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#1e293b", "primaryTextColor": "#f8fafc", "primaryBorderColor": "#334155", "lineColor": "#64748b", "secondaryColor": "#0f172a", "tertiaryColor": "#1e293b"}} }%%

%% ============================================================
%% SMARTUR — C4 Model: Container Diagram
%% Level 2: Containers within the SMARTUR System Boundary
%% ============================================================

C4Container
    title SMARTUR — C4 Container Diagram

    Person(tourist, "Tourist", "B2C end-user seeking personalized POI recommendations")
    Person(serviceOwner, "Service Owner", "B2B operator managing tourism service registration and certifications")
    Person(admin, "Administrator", "Platform operator with full CRUD and analytics access")

    System_Boundary(smartur, "SMARTUR Platform (Docker Compose — smartur-net)") {

        %% ── Presentation Layer ──────────────────────────────────────────
        Container(landing, "LANDING", "Astro 5.16 / React 19 (Islands)", "B2B onboarding portal. Multilingual (ES/EN/FR). Funnels tourists downstream via PUBLIC_TOURIST_APP_URL. Port 4321.")

        Container(plataforma, "PLATAFORMA", "React 19.2 / Vite 7.2 / TypeScript 5.9", "Dual-mode SPA. Routes: / (tourist landing), /form (AI Recommendation Wizard, role=2), /dashboard/* (admin panel, role=1). Port 5173.")

        %% ── Business Logic Layer ────────────────────────────────────────
        Container(api, "API", "Node.js / Express (CJS)", "Stateless REST API. JWT + Google OAuth auth, RBAC middleware, ownership guards. Serves all business CRUD, certifications, analytics, and user management. /api/v2. Port 3000 (internal) / 4000 (host).")

        %% ── Inference Layer ─────────────────────────────────────────────
        Container_Boundary(modelo_boundary, "MODELO — Hybrid Inference Service (Port 8000)") {
            Container(modelo_api, "FastAPI / Uvicorn", "Python 3.14 / ASGI", "Stateless inference API. Endpoints: POST /recommend/{user_id}, GET /recommend/{user_id}, POST /train-rf, GET /health, GET /health/poi-db.")
            Container(engine, "SmarturEngine", "scikit-learn / scipy.sparse", "Collaborative Filtering. Builds sparse user-item matrix from CSV interactions. Computes Pearson similarity via mean-centering. Provides candidate pool (KNN, top-200).")
            Container(rf_model, "SmarturContextModel", "scikit-learn RandomForestRegressor", "Contextual ranking model. Feature vector: item attributes + user context (budget, age, tourism type, group, accessibility, outdoor). Persisted to .joblib. Retrained via POST /train-rf.")
            Container(fusion, "fusion.py", "Python", "Two-phase Retrieval→Ranking pipeline. Phase A: candidate pool + hard filter (binary constraints) + soft filter (category affinity). Phase B: CF/RF score blend. final_score = α·pred_cf + (1-α)·pred_rf. Diversity re-ranking (max 2 per category).")
            Container(poi_repo, "poi_repository.py", "psycopg2", "Persistence-ignorant data access for inference. Fetches live POIs and traveler profiles from PostgreSQL. Decouples ML pipeline from primary API schema.")
        }

        %% ── Persistence Layer ───────────────────────────────────────────
        ContainerDb(postgres, "PostgreSQL 16", "Relational Database", "Primary store. Business entities, users, certifications, POIs, tourism metrics, traveler profiles. Named volume: postgres_data. Port 5432.")

        ContainerDb(redis, "Redis 7", "Key-Value Cache", "Stateless session cache and rate-limit state for the API service. Password-protected. Named volume: redis_data. Port 6379.")

        %% ── Observability ───────────────────────────────────────────────
        Container(grafana, "Grafana", "Grafana OSS", "Operational dashboards. Tourism analytics and service health metrics. Named volume: grafana_data. Port 4001.")
    }

    %% ── External Systems ────────────────────────────────────────────────
    System_Ext(cloudinary, "Cloudinary", "Cloud media storage. POI images, user avatars.")
    System_Ext(google_oauth, "Google OAuth 2.0", "Federated authentication provider.")
    System_Ext(smtp, "SMTP (Gmail)", "Transactional email via Nodemailer.")

    %% ── Relationships ───────────────────────────────────────────────────

    %% Users → Frontend
    Rel(tourist, landing, "Discovers platform via", "HTTPS")
    Rel(tourist, plataforma, "Explores POIs & submits AI wizard", "HTTPS")
    Rel(serviceOwner, landing, "Registers business", "HTTPS")
    Rel(admin, plataforma, "Manages platform via /dashboard", "HTTPS")

    %% LANDING → PLATAFORMA
    Rel(landing, plataforma, "Redirects tourists via PUBLIC_TOURIST_APP_URL", "HTTP (internal DNS)")

    %% PLATAFORMA → API (standard requests)
    Rel(plataforma, api, "CRUD, auth, POI data, certifications", "HTTP REST + JWT — VITE_API_URL")

    %% PLATAFORMA → MODELO (direct inference — bypasses API)
    Rel(plataforma, modelo_api, "POST /recommend/{user_id} with context vector", "HTTP REST — VITE_MODELO_URL [KNOWN RISK: direct browser→inference, no auth enforcement]")

    %% API → Persistence
    Rel(api, postgres, "Reads/writes all business entities", "SQL via pg (node-postgres)")
    Rel(api, redis, "Session cache, rate-limit state", "Redis protocol")

    %% API → External
    Rel(api, cloudinary, "Uploads images", "HTTPS SDK")
    Rel(api, google_oauth, "Verifies OAuth tokens", "HTTPS")
    Rel(api, smtp, "Sends transactional emails", "SMTP TLS")

    %% MODELO internal
    Rel(modelo_api, fusion, "Delegates inference to", "In-process")
    Rel(fusion, engine, "Phase A: candidate pool (KNN/Pearson)", "In-process")
    Rel(fusion, rf_model, "Phase B: contextual re-ranking", "In-process")
    Rel(fusion, poi_repo, "Fetches live local POIs", "In-process")
    Rel(poi_repo, postgres, "SELECT POIs & traveler profiles", "SQL via psycopg2")

    %% Observability
    Rel(grafana, postgres, "Reads analytics metrics", "SQL")

    UpdateLayoutConfig($c4ShapeInRow="3", $c4BoundaryInRow="1")
