---
import { ui } from "../i18n/ui";
import Button from "./Button.astro";

interface Props {
  lang?: keyof typeof ui;
}

const { lang = "es" } = Astro.props;
const t = ui[lang];

const REASONS = [
  { value: "download",   label: t["contact.reason.download"] },
  { value: "join",       label: t["contact.reason.join"] },
  { value: "tourist",    label: t["contact.reason.tourist"] },
  { value: "pricing",    label: t["contact.reason.pricing"] },
  { value: "evaluation", label: t["contact.reason.evaluation"] },
  { value: "suggestion", label: t["contact.reason.suggestion"] },
  { value: "other",      label: t["contact.reason.other"] },
];
---

<div class="cta-minimal bg-[var(--color-bg)] transition-colors duration-300 py-16 sm:py-20 md:py-24 lg:py-32">
  <div class="container mx-auto px-4 sm:px-6 md:px-12 max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 lg:gap-24 items-center">

      <!-- Left: title -->
      <div class="cta-content-left reveal-fade-up">
        <span class="block text-sm font-semibold tracking-widest uppercase text-[var(--color-purple)] mb-4">
          {t["contact.cta.label"]}
        </span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-[var(--color-text)] leading-tight">
          {t["contact.cta.title"]}
        </h2>
      </div>

      <!-- Right: email step + success -->
      <div class="cta-content-right reveal-fade-up" style="animation-delay: 200ms;">
        <p class="text-base sm:text-lg text-[var(--color-text-alt)] mb-6 sm:mb-8 leading-relaxed max-w-md">
          {t["contact.cta.text"]}
        </p>

        <!-- Step 1: email capture -->
        <form id="contact-email-step" class="flex flex-col sm:flex-row gap-3 w-full max-w-lg" novalidate>
          <input
            type="email"
            name="email"
            placeholder={t["contact.cta.emailPlaceholder"]}
            required
            autocomplete="email"
            class="w-full flex-grow min-w-0 bg-[var(--color-bg-alt)] border border-[rgba(var(--rgb-text),0.12)] text-[var(--color-text)] rounded-full py-3 sm:py-4 px-4 sm:px-6 outline-none focus:ring-2 focus:ring-[var(--color-purple)] transition-all duration-300 ease-out placeholder:opacity-60"
          />
          <Button
            type="submit"
            title={t["contact.cta.continue"]}
            color="primary-alt"
            arrow
            class="w-full sm:w-auto whitespace-nowrap shadow-md hover:-translate-y-0.5"
          />
        </form>

        <!-- Success state -->
        <div id="contact-success" hidden class="flex items-center gap-3 py-4 font-semibold" style="color: #10b981;">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span>{t["contact.form.success"]}</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal dialog -->
<dialog
  id="contact-dialog"
  aria-labelledby="dialog-title"
  class="rounded-2xl p-0 w-[calc(100vw-2rem)] max-w-lg shadow-2xl border"
  style="background: var(--color-bg); border-color: var(--color-border);"
>
  <div class="p-6 sm:p-8">
    <!-- Header -->
    <div class="flex items-start justify-between mb-1">
      <h3 id="dialog-title" class="text-xl font-bold" style="color: var(--color-text);">
        {t["contact.modal.title"]}
      </h3>
      <button
        type="button"
        id="dialog-close"
        class="ml-4 shrink-0 rounded-lg p-1 transition-opacity opacity-50 hover:opacity-100"
        style="color: var(--color-text-alt);"
        aria-label="Cerrar"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <p class="text-sm mb-5" style="color: var(--color-text-alt);">{t["contact.modal.subtitle"]}</p>

    <!-- Error -->
    <div id="modal-error" hidden class="mb-4 flex items-center gap-2 rounded-xl px-4 py-2.5 text-sm font-medium" style="color:#ef4444; background:rgba(239,68,68,0.08);">
      <svg xmlns="http://www.w3.org/2000/svg" class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span id="modal-error-text"></span>
    </div>

    <!-- Full form -->
    <form id="contact-full-form" novalidate class="flex flex-col gap-4">

      <!-- Email (pre-filled from step 1) -->
      <input
        type="email"
        name="email"
        placeholder={t["contact.cta.emailPlaceholder"]}
        autocomplete="email"
        class="w-full bg-[var(--color-bg-alt)] border border-[rgba(var(--rgb-text),0.12)] text-[var(--color-text)] rounded-full py-3 px-5 outline-none focus:ring-2 focus:ring-[var(--color-purple)] transition-all placeholder:opacity-60"
      />

      <!-- Reason -->
      <div class="relative">
        <select
          name="reason"
          required
          class="w-full appearance-none bg-[var(--color-bg-alt)] border border-[rgba(var(--rgb-text),0.12)] text-[var(--color-text)] rounded-full py-3 pl-5 pr-10 outline-none focus:ring-2 focus:ring-[var(--color-purple)] transition-all"
        >
          <option value="" disabled selected style="color: var(--color-text-alt);">{t["contact.reason.placeholder"]}</option>
          {REASONS.map((r) => <option value={r.value}>{r.label}</option>)}
        </select>
        <svg xmlns="http://www.w3.org/2000/svg" class="absolute right-4 top-1/2 -translate-y-1/2 size-4 pointer-events-none opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>

      <!-- Message -->
      <textarea
        name="message"
        rows="4"
        placeholder={t["contact.modal.messagePlaceholder"]}
        class="w-full resize-y bg-[var(--color-bg-alt)] border border-[rgba(var(--rgb-text),0.12)] text-[var(--color-text)] rounded-2xl py-3 px-5 outline-none focus:ring-2 focus:ring-[var(--color-purple)] transition-all placeholder:opacity-60 text-sm"
      ></textarea>

      <!-- Actions -->
      <div class="flex flex-col-reverse sm:flex-row gap-3 sm:justify-end">
        <button
          type="button"
          id="dialog-cancel"
          class="rounded-full px-5 py-2.5 text-sm font-medium transition-colors border"
          style="color: var(--color-text-alt); border-color: var(--color-border);"
        >
          {t["contact.modal.cancel"]}
        </button>
        <button
          type="submit"
          id="modal-submit"
          class="rounded-full px-6 py-2.5 text-sm font-semibold text-white transition-all hover:-translate-y-0.5 active:scale-[0.97] disabled:opacity-50 disabled:cursor-not-allowed"
          style="background: var(--color-purple);"
        >
          {t["contact.modal.submit"]}
        </button>
      </div>
    </form>
  </div>
</dialog>

<script define:vars={{
  reasonRequired: t["contact.form.reasonRequired"],
  messageShort:   t["contact.form.messageShort"],
  sending:        t["contact.form.sending"],
  submitLabel:    t["contact.modal.submit"],
}}>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
  );
  document.querySelectorAll(".reveal-fade-up").forEach((el) => observer.observe(el));

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  const emailStep    = document.getElementById("contact-email-step");
  const dialog       = document.getElementById("contact-dialog");
  const fullForm     = document.getElementById("contact-full-form");
  const successDiv   = document.getElementById("contact-success");
  const dialogClose  = document.getElementById("dialog-close");
  const dialogCancel = document.getElementById("dialog-cancel");
  const modalError   = document.getElementById("modal-error");
  const modalErrText = document.getElementById("modal-error-text");
  const modalSubmit  = document.getElementById("modal-submit");

  function showError(msg) {
    modalErrText.textContent = msg;
    modalError.removeAttribute("hidden");
  }
  function hideError() {
    modalError.setAttribute("hidden", "");
  }

  // Step 1 → open dialog
  emailStep.addEventListener("submit", (e) => {
    e.preventDefault();
    const email = (new FormData(emailStep).get("email") ?? "").toString().trim();
    if (!EMAIL_RE.test(email)) return;
    fullForm.querySelector('input[name="email"]').value = email;
    hideError();
    dialog.showModal();
  });

  dialogClose.addEventListener("click", () => dialog.close());
  dialogCancel.addEventListener("click", () => dialog.close());
  // Close on backdrop click
  dialog.addEventListener("click", (e) => { if (e.target === dialog) dialog.close(); });

  // Step 2 → submit
  fullForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const fd      = new FormData(fullForm);
    const email   = (fd.get("email") ?? "").toString().trim();
    const reason  = (fd.get("reason") ?? "").toString();
    const message = (fd.get("message") ?? "").toString().trim();

    hideError();
    if (!reason)          { showError(reasonRequired); return; }
    if (message.length < 10) { showError(messageShort); return; }

    modalSubmit.disabled = true;
    modalSubmit.textContent = sending;

    try {
      const res = await fetch("/api/v2/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, reason, message, source: "landing_b2b" }),
      });
      if (!res.ok) throw new Error("server");
      dialog.close();
      emailStep.setAttribute("hidden", "");
      successDiv.removeAttribute("hidden");
    } catch {
      showError("No se pudo enviar. Intenta de nuevo.");
    } finally {
      modalSubmit.disabled = false;
      modalSubmit.textContent = submitLabel;
    }
  });
</script>

<style is:global>
  #contact-dialog::backdrop {
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
</style>

<style>
  .reveal-fade-up {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.8s cubic-bezier(0.2, 0.8, 0.2, 1),
      transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .reveal-fade-up.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
