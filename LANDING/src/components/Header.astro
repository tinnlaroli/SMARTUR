---
import { Image } from "astro:assets";
import Button from "./Button.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import ThemeToggle from "./ThemeToggle.astro";
import logoImage from "../assets/imgs/logo.png";
import type { Link } from "../types";

interface Props {
  logoUrl: string;
  logoAlt: string;
  links: Link[];
  link1?: Link;
  link2?: Link;
  mobileMenuLabel?: string;
}

const {
  logoUrl,
  logoAlt,
  link1,
  link2,
  links,
  mobileMenuLabel = "Toggle Menu",
} = Astro.props;
---

<header>
  <nav class="navbar">
    <div class="inner">
      <div class="wrapper">
        <a class="logo" href={logoUrl}>
          <Image
            src={logoImage}
            alt={logoAlt}
            loading="eager"
            decoding="async"
            fetchpriority="high"
            width={160}
            height={48}
          />
          <span class="u-sr-only">{logoAlt}</span>
        </a>

        <div class="menu">
          <ul>
            {
              links.map((l) => (
                <li>
                  <a href={l.url}>{l.title}</a>
                </li>
              ))
            }
          </ul>
          <div class="menu-controls">
            <LanguageSwitcher />
            <ThemeToggle />
          </div>
        </div>

        <div class="buttons">
          {
            link1 ? (
              <Button
                url={link1.url}
                title={link1.title}
                color="cyan"
                size="md"
                target="_blank"
                revealable={false}
                external
              />
            ) : null
          }
          {link2 ? (
            <Button {...link2} revealable={false} class="signup" />
          ) : null}

          <div class="controls">
            <LanguageSwitcher />
            <ThemeToggle />
          </div>

          <button type="button" class="toggle" aria-label={mobileMenuLabel}>
            <span class="u-sr-only">{mobileMenuLabel}</span>
            <span aria-hidden>
              <span></span>
              <span></span>
              <span></span>
            </span>
          </button>
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  nav.navbar {
    --br: 50px;

    position: fixed;
    top: 0.75rem;
    left: 0;
    right: 0;
    z-index: 9999;
    color: var(--color-text);
    margin: 0 auto;
    padding: 0.5rem 0;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    transition: transform 0.3s var(--ease-out-cubic);
    pointer-events: auto;
    display: flex;
    align-items: center;
    justify-content: center;

    /* When menu is open, disable the transform to avoid stacking context issues */
    :global(body.is-nav-opened) & {
      transform: none !important;
    }

    /* ... existing styles ... */
    :global(body.is-nav-hidden) & {
      transform: translateY(calc(-100% - 0.75rem));
    }

    @media (--mq-tablet-sm) {
      --br: 1rem;
      top: 0.5rem;
    }
  }

  .inner {
    margin-left: auto;
    margin-right: auto;
    width: calc(100% - 2rem);
    max-width: 1400px;
    padding: 0;
    transition: padding 0.3s var(--ease-out-cubic);

    :global(body.is-nav-small) & {
      padding: 0;
    }
  }

  .wrapper {
    position: relative;
    z-index: 9999;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2.25rem;
    padding: 0.5rem 1.75rem;
    box-sizing: border-box;
    max-width: 1360px;
    margin: 0 auto;
    border-radius: var(--br);
    background: rgba(var(--rgb-bg), 0.88) !important;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08);
    border: 1px solid var(--color-border);
    transition: box-shadow 0.3s var(--ease-out-cubic);
    pointer-events: auto;

    @media (--mq-tablet) {
      gap: 1.25rem;
      padding: 0.5rem 0.75rem;
    }
    @media (--mq-phone) {
      gap: 0.5rem;
      padding: 0.35rem 0.5rem;
      justify-content: space-between;
    }
  }

  :global(body.is-nav-small) .wrapper {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
  }

  .logo {
    position: relative;
    z-index: 3;
    flex-shrink: 0;

    img {
      height: 2.25rem;
      width: auto;
    }

    @media (--mq-phone) {
      img {
        height: 2rem;
      }
    }
  }

  .menu {
    display: flex;
    margin-left: 2rem;
    width: auto;
    pointer-events: auto;
    z-index: 9999;

    /* Adjust menu item spacing */
    @media (--mq-tablet) {
      :global(ul) {
        gap: 1.25em;
      }
    }

    @media (--mq-tablet) {
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100vh;
      height: 100dvh;
      position: fixed;
      z-index: 2;
      background: rgba(var(--rgb-bg), 0.98);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      top: 0;
      left: 0;
      margin: 0;
      clip-path: inset(0 0 0%);
      transition: clip-path 0.5s var(--ease-out-expo);
      flex-direction: column;
      gap: 2rem;
      padding: 6rem var(--container-offset) 2rem;

      :global(body:not(.is-nav-opened)) & {
        clip-path: inset(0 0 100%);
        pointer-events: none;
      }

      :global(body.is-nav-small:not(.is-nav-opened)) & {
        clip-path: inset(
          0 0 calc(100% - 3.75rem) round 0 0 var(--br) var(--br)
        );
      }
    }

    @media (--mq-phone) {
      :global(body.is-nav-small:not(.is-nav-opened)) & {
        clip-path: inset(0 0 calc(100% - 3.375rem) round 0 0 1rem 1rem);
      }
    }

    :global(ul) {
      @extend %u-text;

      --fs: 15px;
      --fw: 700;
      display: flex;
      list-style: none;
      padding: 0;
      margin: 0;
      align-items: center;
      gap: 1.75em;

      @media (--mq-tablet) {
        flex-direction: column;
        font-size: 2rem;
        gap: 1rem;
        color: var(
          --color-text
        ) !important; /* Force text color for visibility */
      }

      :global(li) {
        display: flex;
        align-items: center;
        gap: 1.3125em;

        @media (--mq-tablet) {
          flex-direction: column;
          gap: 1rem;
          opacity: 0;
          transform: translateY(20px);
          transition:
            opacity 0.4s ease,
            transform 0.4s ease;
        }

        &::after {
          display: inline-block;
          content: "";
          width: 2px;
          height: 2px;
        }

        &:last-child {
          &::after {
            display: none;
          }
        }
      }

      :global(a) {
        text-decoration: none;
        position: relative;
        color: var(--color-text) !important; /* Ensure links are visible */

        @media (--mq-tablet) {
          color: var(--color-text) !important;
          font-weight: 500;
        }

        &::before {
          content: "";
          position: absolute;
          height: 2px;
          background: currentcolor;
          top: 115%;
          width: 100%;
          left: 0;
          pointer-events: none;
          transform: scaleX(0);
          transition: transform 0.3s var(--ease-out-expo);
          transform-origin: right;
        }

        &:hover,
        &:focus {
          color: var(--color-purple) !important;

          &::before {
            transform: scaleX(1);
            transform-origin: left;
          }
        }

        &.is-active,
        &:global(.is-active) {
          color: var(--color-purple) !important;

          &::before {
            transform: scaleX(1);
            transform-origin: left;
            background: var(--color-purple);
          }
        }
      }
    }
  }

  .buttons {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    z-index: 2;
    margin-left: auto; /* Required to push it to the right on desktop */

    @media (--mq-tablet) {
      gap: 0.75rem;
      position: relative;
      z-index: 100;
    }

    @media (--mq-tablet) {
      gap: 0.75rem;
    }

    @media (--mq-phone) {
      margin-left: 0; /* Remove auto margin on mobile if it forces layout shifts */
      gap: 0.5rem;
    }
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-left: 1rem;
    margin-left: 1rem;
    border-left: 1px solid rgba(var(--rgb-text), 0.1);

    @media (--mq-tablet) {
      padding-left: 0.75rem;
      margin-left: 0.75rem;
    }

    @media (--mq-tablet) {
      border-left: none;
      padding-left: 0;
      margin-left: 0;
    }
  }

  @media (--mq-phone) {
    .buttons :global(.btn) {
      display: none;
    }
  }

  .menu-controls {
    display: none;
  }

  @media (--mq-phone) {
    .controls {
      display: none;
    }

    .menu-controls {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }
  }

  .controls :global(button) {
    background: rgba(var(--rgb-text), 0.06);
    border-radius: 12px;
    transition: background 0.3s ease;
    color: var(--color-text);
    padding: 0.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .controls :global(button:hover) {
    background: rgba(var(--rgb-text), 0.12);
  }

  .signup {
    @media (--mq-phone) {
      display: none;
    }
  }

  .toggle {
    border: none;
    background: none;
    padding: 0.75rem;
    margin: -0.75rem;
    cursor: pointer;
    align-self: center;
    align-items: center;
    justify-content: center;
    display: none;
    position: relative;
    z-index: 110;
    color: var(--color-text);
    transition: color 0.3s var(--ease-out-expo);
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
    min-width: 44px;
    min-height: 44px;

    :global(.has-no-bg &) {
      color: var(--color-pink);
    }

    :global(body.is-nav-opened) &,
    :global(body.is-nav-small) & {
      color: var(--color-purple);
    }

    @media (--mq-tablet) {
      display: flex;
    }

    > span:last-child {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 1.25rem;
      width: 1.75rem;

      span {
        display: block;
        width: 100%;
        height: 3px;
        background: currentColor;
        border-radius: 10px;
        transition:
          transform 0.2s var(--ease-out-cubic),
          opacity 0.2s;
        transform: translateZ(0);

        &:nth-child(2) {
          transition-property: opacity;
        }
      }
    }

    :global(body.is-nav-opened) & {
      color: var(--color-purple);

      > span {
        span {
          &:first-child {
            transform: translateY(calc(0.625rem - 1.5px)) rotate(45deg);
          }

          &:nth-child(2) {
            opacity: 0;
          }

          &:last-child {
            transform: translateY(calc(-0.625rem + 1.5px)) rotate(-45deg);
          }
        }
      }
    }
  }

  :global(.control-btn) {
    background: rgba(var(--rgb-text), 0.06);
    border-radius: 12px;
    transition: background 0.3s ease;
    color: var(--color-text);
    padding: 0.5rem;
  }

  :global(.control-btn:hover) {
    background: rgba(var(--rgb-text), 0.12);
  }

  /* Active state for navigation links */
  .menu :global(a.is-active) {
    color: var(--color-purple) !important;
  }

  .menu :global(a.is-active::before) {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* Force visibility of links and fix staggered animation explicitly when the mobile nav is opened */
  @media (--mq-tablet) {
    :global(body.is-nav-opened) .menu :global(ul) :global(li) {
      opacity: 1 !important;
      transform: translateY(0) !important;
    }
    :global(body.is-nav-opened) .menu :global(ul) :global(a) {
      color: rgb(var(--rgb-text)) !important;
    }

    :global(body.is-nav-opened) .menu :global(ul) :global(li:nth-child(1)) {
      transition-delay: 0.1s;
    }
    :global(body.is-nav-opened) .menu :global(ul) :global(li:nth-child(2)) {
      transition-delay: 0.2s;
    }
    :global(body.is-nav-opened) .menu :global(ul) :global(li:nth-child(3)) {
      transition-delay: 0.3s;
    }
    :global(body.is-nav-opened) .menu :global(ul) :global(li:nth-child(4)) {
      transition-delay: 0.4s;
    }
    :global(body.is-nav-opened) .menu :global(ul) :global(li:nth-child(5)) {
      transition-delay: 0.5s;
    }
    :global(body.is-nav-opened) .menu :global(ul) :global(li:nth-child(6)) {
      transition-delay: 0.6s;
    }
  }
</style>

<script>
  // Navbar state
  let navState = {
    initialized: false,
    scrollY: 0,
    prevY: 0,
    smallThreshold: 100,
    hiddenThreshold: 200
  };

  function initNavbar() {
    const navbar = document.querySelector('nav.navbar');
    if (!navbar || navState.initialized) return;
    navState.initialized = true;

    console.log('Initializing navbar');

    // Toggle menu button
    const toggleBtn = navbar.querySelector('.toggle');
    if (toggleBtn) {
      toggleBtn.addEventListener('click', (e) => {
        console.log('Toggle clicked');
        e.preventDefault();
        e.stopPropagation();
        document.body.classList.toggle('is-nav-opened');
      });
    }

    // Close menu and navigate when clicking links
    const menuLinks = navbar.querySelectorAll('.menu a[href^="#"]');
    menuLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        console.log('Link clicked:', link.href);
        document.body.classList.remove('is-nav-opened');
        document.body.style.overflow = '';
      });
    });

    // Scroll spy - highlight active section
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            const link = navbar.querySelector(`.menu a[href="#${id}"]`);
            if (link) {
              navbar.querySelectorAll('.menu a').forEach(l => l.classList.remove('is-active'));
              link.classList.add('is-active');
            }
          }
        });
      },
      { rootMargin: '-20% 0px -60% 0px', threshold: 0 }
    );

    menuLinks.forEach(link => {
      const href = link.getAttribute('href');
      if (href && href.length > 1) {
        const id = href.substring(1);
        const section = document.getElementById(id);
        if (section) observer.observe(section);
      }
    });
  }

  // Scroll handler for hide/show navbar
  function handleScroll() {
    navState.scrollY = window.scrollY;
    const classList = document.body.classList;

    // Show/hide navbar on scroll
    const shouldBeSmall = navState.scrollY > navState.smallThreshold;
    const isSmall = classList.contains('is-nav-small');
    if (shouldBeSmall !== isSmall) {
      classList.toggle('is-nav-small', shouldBeSmall);
    }

    const isDown = navState.scrollY > navState.prevY;
    const shouldBeHidden = navState.scrollY > navState.hiddenThreshold && isDown;
    const isHidden = classList.contains('is-nav-hidden');
    if (shouldBeHidden !== isHidden) {
      classList.toggle('is-nav-hidden', shouldBeHidden);
    }

    navState.prevY = navState.scrollY;
  }

  // Initialize when DOM is ready
  function initAll() {
    initNavbar();
    window.addEventListener('scroll', handleScroll, { passive: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }

  // Re-initialize on Astro navigation
  document.addEventListener('astro:after-swap', () => {
    navState.initialized = false;
    initAll();
  });
</script>
