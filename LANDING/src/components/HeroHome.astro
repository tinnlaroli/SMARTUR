---
import type { Link } from "../types";
import Button from "./Button.astro";
import { useTranslations, defaultLang } from "../i18n/utils";
import { ui } from "../i18n/ui";

interface Props {
  lang?: keyof typeof ui;
  title: string;
  subtitle?: string;
  cta?: Link;
}

const { lang = defaultLang, title, subtitle, cta } = Astro.props;
const t = useTranslations(lang);
---

<script>document.documentElement.classList.add('js-ready');</script>
<div class="sy-hero-home" id="hero-section">
  <div class="hero-shimmer"></div>
  <div class="hero-bg-visual" aria-hidden="true">
    <div class="hero-blob hero-blob-1" />
    <div class="hero-blob hero-blob-2" />
    <div class="hero-blob hero-blob-3" />
    <div class="hero-grid-pattern" />
  </div>

  <div class="u-container container">
    <div class="inner">
      <div class="content">
        <h1 class="u-heading title hero-title" set:html={title} />
        {subtitle ? (
          <p class="u-text subtitle hero-subtitle">{subtitle}</p>
        ) : null}
        {cta ? (
          <div class="cta-wrapper hero-cta">
            <Button
              {...cta}
              arrow
              color="primary-alt"
              class="cta hero-cta-btn"
              ariaLabel={t("hero.scrollDownAriaLabel")}
            />
            <div class="cta-shimmer" />
          </div>
        ) : null}
      </div>
    </div>
  </div>

  <button
    type="button"
    class="scroll-indicator"
    aria-label={t("hero.scrollDownAriaLabel")}
  >
    <span>{t("hero.scrollIndicator")}</span>
    <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path d="M6 9l6 6 6-6" />
    </svg>
  </button>
</div>

<style>
  .sy-hero-home {
    position: relative;
    overflow: hidden;
    background: transparent !important;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      transparent 0%,
      rgba(var(--rgb-purple-accent), 0.06) 30%,
      rgba(var(--rgb-pink-primary), 0.08) 50%,
      rgba(var(--rgb-cyan-accent), 0.06) 70%,
      transparent 100%
    );
    transform: translateX(-100%);
    z-index: 0;
    pointer-events: none;
    opacity: 0;
  }

  /* Background visual element — decorative blobs */
  .hero-bg-visual {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.15;
    will-change: transform;
  }

  .hero-blob-1 {
    width: 45vmax;
    height: 45vmax;
    right: -10vmax;
    top: -5vmax;
    background: radial-gradient(circle, rgba(var(--rgb-purple-accent), 0.6) 0%, transparent 70%);
    animation: heroBlobFloat 20s ease-in-out infinite alternate;
  }

  .hero-blob-2 {
    width: 35vmax;
    height: 35vmax;
    right: 5vmax;
    bottom: -10vmax;
    background: radial-gradient(circle, rgba(var(--rgb-cyan-accent), 0.5) 0%, transparent 70%);
    animation: heroBlobFloat 25s ease-in-out infinite alternate-reverse;
  }

  .hero-blob-3 {
    width: 25vmax;
    height: 25vmax;
    right: 20vmax;
    top: 30%;
    background: radial-gradient(circle, rgba(var(--rgb-pink-primary), 0.4) 0%, transparent 70%);
    animation: heroBlobFloat 18s ease-in-out infinite alternate;
  }

  @keyframes heroBlobFloat {
    0% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-3vmax, 2vmax) scale(1.1); }
    66% { transform: translate(2vmax, -3vmax) scale(0.9); }
    100% { transform: translate(-2vmax, 1vmax) scale(1.05); }
  }

  .hero-grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, rgba(var(--rgb-text), 0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.5;
  }

  .container {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    align-items: center;
  }

  .inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 0;
    position: relative;
    width: 100%;

    @media (--mq-desktop-lg) {
      padding: 3rem 0;
    }

    @media (--mq-tablet) {
      padding: 3rem 0 2rem;
    }

    @media (--mq-phone) {
      padding: 5rem 0 1rem;
    }

    @media (--mq-phone-sm) {
      padding: 4.5rem 0 1rem;
    }
  }

  .content {
    max-width: 860px;
    z-index: 2;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;

    @media (--mq-tablet) {
      max-width: 100%;
    }
  }

  .title {
    --fs: var(--font-size-display-lg);
    --lh: var(--line-height-display);
    --fw: 900;
    --ls: var(--letter-spacing-display);
    color: var(--color-text);
  }

  .js-ready .hero-title {
    opacity: 0;
    transform: translateY(40px);
  }

  .js-ready .hero-subtitle {
    opacity: 0;
    transform: translateY(30px);
    filter: blur(8px);
  }

  .js-ready .hero-cta {
    opacity: 0;
    transform: scale(0.7);
  }

  .sy-hero-home.hero-revealed .hero-title,
  .sy-hero-home.hero-revealed .hero-subtitle,
  .sy-hero-home.hero-revealed .hero-cta,
  .sy-hero-home.hero-revealed .scroll-indicator {
    opacity: 1;
    transform: none;
    filter: none;
  }

  .subtitle {
    --fs: var(--font-size-lg);
    max-width: 32em;
    margin-top: 1.75rem;
    line-height: 1.65;
    color: var(--color-text-alt);

    @media (--mq-phone) {
      --fs: var(--font-size-md);
    }
  }

  /* ─── CTA Button ─── */
  .cta-wrapper {
    position: relative;
    display: inline-block;
    overflow: hidden;
    margin-top: 2.75rem;
  }

  .cta-shimmer {
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.3),
      transparent
    );
    transform: skewX(-20deg);
    pointer-events: none;
    z-index: 5;
  }

  /* ─── Scroll Indicator ─── */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    border: none;
    background: none;
    cursor: pointer;
    padding: 0;
    color: var(--color-text-alt);
    z-index: 10;
    opacity: 0;

    @media (min-width: 768px) {
      display: flex;
    }

    span {
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    .chevron {
      width: 2rem;
      height: 2rem;
      animation: chevronBounce 2.5s ease-in-out infinite;
    }

    &:hover {
      color: var(--color-purple);
    }
  }

  @keyframes chevronBounce {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50% { transform: translateY(6px); opacity: 1; }
  }

  /* ─── Responsive blob adjustments ─── */
  @media (--mq-tablet) {
    .hero-blob-1 {
      width: 60vmax;
      height: 60vmax;
      right: -15vmax;
      opacity: 0.1;
    }
    .hero-blob-2 {
      width: 50vmax;
      height: 50vmax;
      opacity: 0.1;
    }
    .hero-blob-3 {
      display: none;
    }
  }

  @media (--mq-phone) {
    .hero-blob-1 {
      width: 80vmax;
      height: 80vmax;
      right: -25vmax;
      top: auto;
      bottom: -10vmax;
      opacity: 0.08;
    }
    .hero-blob-2 {
      display: none;
    }
  }
</style>

<script>
  import gsap from "gsap";

  let heroAnimated = false;

  function animateHero() {
    if (heroAnimated) return;
    heroAnimated = true;

    const hero = document.getElementById("hero-section");
    if (!hero) return;

    hero.classList.remove("hero-revealed");

    const titleEl = hero.querySelector(".hero-title") as HTMLElement;
    const subtitleEl = hero.querySelector(".hero-subtitle") as HTMLElement;
    const ctaEl = hero.querySelector(".hero-cta") as HTMLElement;
    const shimmerEl = hero.querySelector(".hero-shimmer") as HTMLElement;
    const ctaShimmer = hero.querySelector(".cta-shimmer") as HTMLElement;
    const scrollIndicatorEl = hero.querySelector(".scroll-indicator") as HTMLElement;

    gsap.set([titleEl, subtitleEl, ctaEl], { opacity: 0 });
    if (scrollIndicatorEl) gsap.set(scrollIndicatorEl, { opacity: 0, y: -12 });

    if (titleEl) gsap.set(titleEl, { y: 40 });
    if (subtitleEl) gsap.set(subtitleEl, { y: 30, filter: "blur(8px)" });
    if (ctaEl) gsap.set(ctaEl, { scale: 0.7 });

    const tl = gsap.timeline({
      defaults: { ease: "power3.out" },
      onComplete() {
        hero.classList.add("hero-revealed");
      },
    });

    // Background shimmer
    if (shimmerEl) {
      tl.to(shimmerEl, { opacity: 1, x: "200%", duration: 1.5, ease: "power2.inOut" }, 0);
      tl.to(shimmerEl, { opacity: 0, duration: 0.5 }, 1.2);
    }

    // Title
    if (titleEl) {
      tl.to(titleEl, { opacity: 1, y: 0, duration: 0.7 }, 0.1);
    }

    // Subtitle
    if (subtitleEl) {
      tl.to(subtitleEl, { opacity: 1, y: 0, filter: "blur(0px)", duration: 1 }, 0.5);
    }

    // CTA
    if (ctaEl) {
      tl.to(ctaEl, { opacity: 1, scale: 1, duration: 1, ease: "elastic.out(1, 0.5)" }, 0.7);
      if (ctaShimmer) {
        tl.to(ctaShimmer, { left: "150%", duration: 0.8, ease: "power2.inOut" }, 1.2);
      }
    }

    // Scroll indicator
    if (scrollIndicatorEl) {
      tl.to(scrollIndicatorEl, { opacity: 1, y: 0, duration: 1, ease: "power2.out" }, 1.5);
    }
  }

  window.addEventListener("smartur:loaded", () => {
    animateHero();
  }, { once: true });

  if (!document.body.classList.contains("is-loading")) {
    const _t = setTimeout(() => { animateHero(); }, 100);
    document.addEventListener('astro:before-swap', () => clearTimeout(_t), { once: true });
  }

  // Scroll indicator click
  const indicator = document.querySelector(".scroll-indicator");
  if (indicator) {
    indicator.addEventListener("click", () => {
      const nextSection =
        document.getElementById("region") ??
        document.getElementById("nosotros") ??
        document.getElementById("home");
      if (nextSection) {
        nextSection.scrollIntoView({ behavior: "smooth" });
      }
    });
  }

  // Hero CTA → scroll to #empresa (prevents page reload on hash click)
  function bindHeroCta() {
    const ctaBtn = document.querySelector("a.hero-cta-btn");
    if (!ctaBtn) return;
    ctaBtn.addEventListener("click", (e) => {
      const href = (ctaBtn as HTMLAnchorElement).getAttribute("href");
      if (!href || !href.startsWith("#")) return;
      e.preventDefault();
      const target = document.getElementById(href.slice(1));
      if (!target) return;
      const smoother = (window as any).__smoother__;
      if (smoother) {
        smoother.scrollTo(href, true, "top top");
      } else {
        target.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }, { once: false });
  }

  bindHeroCta();
  document.addEventListener("astro:page-load", bindHeroCta);
</script>
