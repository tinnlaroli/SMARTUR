---
import RectReveal from "../components/RectReveal.astro";

interface Props {
  items: { title: string; text: string }[];
}

const { items } = Astro.props;
---

<div class="sy-statements">
  <RectReveal ignoreLast>
    {
      items.map(({ title, text }, i) => (
        <div class="box">
          <div class="u-container">
            <div class="content">
              <h2
                class="u-heading"
                data-sy-reveal={i === 0 ? "words" : undefined}
                data-sy-reveal-manual={i === 0 ? "" : undefined}
                set:html={title}
              />
              <p 
                class="u-text" 
                data-sy-reveal={i === 0 ? "lines" : undefined}
                data-sy-reveal-manual={i === 0 ? "" : undefined}
              >
                {text}
              </p>
            </div>
          </div>
        </div>
      ))
    }
  </RectReveal>
  <div data-gl-place="0"></div>
</div>

<style>
  [data-gl-place] {
    --d: 1;
    --s: 17rem;
    position: absolute;
    right: 0;
    left: 0;
    margin: 0 auto;
    bottom: 0;

    @media (--mq-tablet) {
      bottom: 50%;
    }
  }

  .sy-statements {
    margin-bottom: 0;
    position: relative;
    z-index: 9;
  }

  .box {
    width: 100%;
    height: 100vh;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    color: var(--color-text);
    text-align: center;
    flex-direction: column;

    @media (--mq-phone) {
      height: auto;
      min-height: 70dvh;
      padding: 3rem var(--container-offset);
    }

    @media (--mq-phone-sm) {
      min-height: 60dvh;
      padding-top: 2.5rem;
      padding-bottom: 2.5rem;
    }

    &:nth-child(2) {
      background: rgb(var(--rgb-pink-primary));
      color: var(--color-white);
    }

    &:nth-child(3) {
      background: rgb(var(--rgb-cyan-accent));
      color: var(--color-white);
    }
  }

  .content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  h2 {
    --fs: 4.5rem;
    --lh: 1.15;
    max-width: 18ch;

    @media (--mq-tablet) {
      --fs: 3.25rem;
    }

    @media (--mq-phone) {
      --fs: 2.25rem;
    }
  }

  p {
    max-width: 50em;
    --fs: var(--font-size-md);
    line-height: 1.6;
    margin-top: 1.5rem;

    @media (--mq-phone) {
      max-width: 100%;
    }
  }
</style>
