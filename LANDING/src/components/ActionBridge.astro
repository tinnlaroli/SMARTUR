---
import { ui } from "../i18n/ui";
import { ArrowRight, Building2, Map, ExternalLink } from "lucide-react";

interface Props {
  lang?: keyof typeof ui;
}

const { lang = "es" } = Astro.props;
const t = ui[lang];
---

<section class="action-bridge-section relative z-20 py-12 md:py-20 lg:py-24">
  <div class="container mx-auto px-4">
    <div class="bridge-card relative p-4 md:p-8 text-center max-w-5xl mx-auto">
      
      <div class="relative z-10 flex flex-col md:flex-row gap-6 md:gap-8 justify-center items-center">
        
        {/* Business CTA (Primary) */}
        <a href="#pricing" class="bridge-action group relative w-full md:w-auto min-w-[320px] shadow-xl hover:shadow-2xl p-4 rounded-[2rem] transition-all duration-300 hover:-translate-y-1" data-sy-reveal="fade">
          <div class="flex items-center gap-5">
            <div class="icon-box w-16 h-16 shrink-0 rounded-full flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
              <Building2 size={32} />
            </div>
            <div class="text-left flex-grow min-w-0">
              <span class="bridge-label block text-xl font-bold transition-colors">{t["action.business.label"]}</span>
              <div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] transition-[grid-template-rows] duration-300 ease-out">
                <span class="bridge-desc overflow-hidden text-sm font-medium block pt-1">
                  {t["action.business.description"]}
                </span>
              </div>
            </div>
            <div class="action-arrow w-10 h-10 rounded-full flex items-center justify-center transition-colors">
              <ArrowRight className="w-5 h-5 transition-colors" />
            </div>
          </div>
        </a>

        {/* Separator (Mobile: Hidden, Desktop: Visible) */}
        <div class="bridge-separator hidden md:block w-px h-12"></div>

        {/* Tourist CTA (Secondary) */}
        <a href={import.meta.env.PUBLIC_TOURIST_APP_URL || "http://2.24.112.25:5173/"} target="_blank" rel="noopener noreferrer" class="bridge-action bridge-action--tourist group relative w-full md:w-auto min-w-[320px] shadow-xl hover:shadow-2xl p-4 rounded-[2rem] transition-all duration-300 hover:-translate-y-1" data-sy-reveal="fade">
          <div class="flex items-center gap-5">
            <div class="icon-box-tourist w-16 h-16 shrink-0 rounded-full flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
              <Map size={32} />
            </div>
            <div class="text-left flex-grow min-w-0">
              <span class="bridge-label-tourist block text-xl font-bold transition-colors">{t["action.tourist.label"]}</span>
               <div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] transition-[grid-template-rows] duration-300 ease-out">
                <span class="bridge-desc overflow-hidden text-sm font-medium block pt-1">
                  {t["action.tourist.description"]}
                </span>
              </div>
            </div>
            <div class="action-arrow-tourist w-10 h-10 rounded-full flex items-center justify-center transition-colors">
              <ExternalLink className="w-5 h-5 transition-colors" />
            </div>
          </div>
        </a>

      </div>
    </div>
  </div>
</section>

<style>
  /* ─── ActionBridge — uses design tokens, no dark mode overrides needed ─── */

  .bridge-action {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    transition: transform 0.35s var(--ease-out-back), box-shadow 0.35s var(--ease-out-cubic);
  }

  .bridge-action:hover {
    transform: translateY(-5px);
    box-shadow:
      0 24px 48px rgba(0, 0, 0, 0.14),
      0 0 0 1px rgba(var(--rgb-purple-accent), 0.18);
  }

  .bridge-action--tourist:hover {
    box-shadow:
      0 24px 48px rgba(0, 0, 0, 0.14),
      0 0 40px -12px rgba(var(--rgb-pink-primary), 0.22);
  }

  /* Business icon */
  .icon-box {
    background: rgba(var(--rgb-purple-accent), 0.08);
    color: var(--color-purple);
    transition: background 0.3s ease, transform 0.3s var(--ease-out-back);
  }

  .bridge-action:hover .icon-box {
    background: rgba(var(--rgb-purple-accent), 0.15);
    transform: scale(1.1);
  }

  .bridge-label {
    color: var(--color-text);
    transition: color 0.3s ease;
  }

  .bridge-action:hover .bridge-label {
    color: var(--color-purple);
  }

  .bridge-desc {
    color: var(--color-text-alt);
  }

  .action-arrow {
    background: var(--color-bg-alt);
    transition: background 0.3s ease, transform 0.3s var(--ease-out-back);
  }

  .action-arrow svg {
    color: var(--color-text-alt);
    transition: color 0.3s ease;
  }

  .bridge-action:hover .action-arrow {
    background: var(--color-purple);
    transform: scale(1.1);
  }

  .bridge-action:hover .action-arrow svg {
    color: #ffffff;
  }

  /* Tourist icon */
  .icon-box-tourist {
    background: var(--color-bg-alt);
    color: var(--color-text-alt);
    transition: background 0.3s ease, transform 0.3s var(--ease-out-back);
  }

  .bridge-action:hover .icon-box-tourist {
    background: rgba(var(--rgb-text), 0.08);
    transform: scale(1.1);
  }

  .bridge-label-tourist {
    color: var(--color-text);
    transition: color 0.3s ease;
  }

  .action-arrow-tourist {
    background: var(--color-bg-alt);
    transition: background 0.3s ease, transform 0.3s var(--ease-out-back);
  }

  .action-arrow-tourist svg {
    color: var(--color-text-alt);
    transition: color 0.3s ease;
  }

  .bridge-action:hover .action-arrow-tourist {
    background: var(--color-text);
    transform: scale(1.1);
  }

  .bridge-action:hover .action-arrow-tourist svg {
    color: var(--color-bg);
  }

  /* Separator */
  .bridge-separator {
    background: var(--color-border);
  }
</style>
