---
import { Image } from "astro:assets";
import logoImage from "../assets/imgs/logo_costado.png";
import type { Link } from "../types";
import { useTranslations, defaultLang } from "../i18n/utils";
import { ui } from "../i18n/ui";

interface Props {
  lang?: keyof typeof ui;
  logoUrl: string;
  logoAlt: string;
  links: Link[];
  slogan?: string;
  description?: string;
  quickLinksTitle?: string;
  contactTitle?: string;
  socialTitle?: string;
  mobileAppTitle?: string;
  mobileAppDownload?: string;
  mobileAppVersion?: string;
  copyright?: string;
  address?: string;
}

const {
  lang = defaultLang,
  logoUrl,
  logoAlt,
  links,
  slogan,
  description,
  quickLinksTitle,
  contactTitle,
  socialTitle,
  mobileAppTitle,
  mobileAppDownload,
  mobileAppVersion,
  copyright,
  address,
} = Astro.props;

const t = useTranslations(lang);

let latestVersion = "v1.0.0";
try {
  const response = await fetch("https://api.github.com/repos/tinnlaroli/smartur-movil/releases/latest");
  if (response.ok) {
    const data = await response.json();
    latestVersion = data.tag_name;
  }
} catch (e) {}
---

<sy-footer>
  <footer>
    <div class="inner">
      <!-- Main grid: branding + 4 columns -->
      <div class="main-grid">

        <!-- Branding -->
        <div class="footer-brand">
          <a class="logo" href={logoUrl}>
            <Image
              src={logoImage}
              alt={logoAlt}
              loading="lazy"
              decoding="async"
              width={160}
              height={48}
              style="filter: var(--logo-filter, none);"
            />
            <span class="u-sr-only">{logoAlt}</span>
          </a>
          {slogan && <p class="slogan">{slogan}</p>}
          {description && <p class="description">{description}</p>}
        </div>

        <!-- Columns -->
        <div class="footer-columns">

          <!-- Quick Links -->
          <div class="footer-column">
            <h3 class="column-title">{quickLinksTitle || t("footer.quicklinks")}</h3>
            <ul>
              {links.map((l) => (
                <li><a href={l.url}>{l.title}</a></li>
              ))}
            </ul>
          </div>

          <!-- Contact -->
          <div class="footer-column">
            <h3 class="column-title">{contactTitle || t("footer.contact")}</h3>
            <ul class="contact-list">
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
                <a href="mailto:smarturutcv@gmail.com">smarturutcv@gmail.com</a>
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
                <a href="tel:+522711730136">271 173 0136</a>
              </li>
              {address && (
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  <span>{address}</span>
                </li>
              )}
            </ul>
          </div>

          <!-- Social -->
          <div class="footer-column">
            <h3 class="column-title">{socialTitle || t("footer.social")}</h3>
            <ul class="social-list">
              <li>
                <a
                  href="https://www.instagram.com/smar_tur?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw=="
                  target="_blank"
                  rel="noopener noreferrer"
                  class="social-link instagram"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                  </svg>
                  <span>Instagram</span>
                </a>
              </li>
            </ul>
          </div>

          <!-- App Download -->
          <div class="footer-column">
            <h3 class="column-title">{mobileAppTitle || t("footer.mobileApp")}</h3>
            <div class="app-download">
              <span class="version-tag">{mobileAppVersion || t("footer.mobileApp.version")}: {latestVersion}</span>
              <a
                href="https://github.com/tinnlaroli/smartur-movil/releases/latest/download/app-release.apk"
                class="download-button"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="7 10 12 15 17 10"/>
                  <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                {mobileAppDownload || t("footer.mobileApp.download")}
              </a>
            </div>
          </div>

        </div>
      </div>

      <!-- Copyright -->
      <p class="cp">© {new Date().getFullYear()} {logoAlt}. {copyright}</p>
    </div>
  </footer>
</sy-footer>

<style>
  sy-footer {
    display: block;
    clip-path: inset(0);

    :global(&.has-no-anim footer) {
      position: static;
    }
  }

  footer {
    background: rgba(var(--rgb-bg), 0.96);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    color: var(--color-text);
    position: relative;
    width: 100%;
    border-top: 1px solid var(--color-border);
  }

  .inner {
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
    padding: 4rem 4rem 2rem;

    @media (--mq-tablet) {
      padding: 3rem 2.5rem 2rem;
    }

    @media (--mq-phone) {
      padding: 2.5rem var(--container-offset) 1.5rem;
    }
  }

  /* Main two-column grid: branding | columns */
  .main-grid {
    display: grid;
    grid-template-columns: 1fr 2.5fr;
    gap: 3rem;
    margin-bottom: 3.5rem;

    @media (--mq-tablet) {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  /* Branding */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .logo {
    display: block;
    width: 11rem;

    @media (--mq-phone) {
      width: 9rem;
    }
  }

  .logo img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .slogan {
    font-size: 0.95rem;
    font-weight: 600;
    font-style: italic;
    color: var(--color-purple);
    margin: 0;
  }

  .description {
    font-size: 0.875rem;
    color: var(--color-text-alt);
    line-height: 1.65;
    margin: 0;
    max-width: 28em;
  }

  /* Four-column grid */
  .footer-columns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    row-gap: 2.5rem;
    column-gap: 1.5rem;

    @media (--mq-tablet) {
      grid-template-columns: repeat(2, 1fr);
      row-gap: 2rem;
      column-gap: 2rem;
    }

    @media (--mq-phone) {
      grid-template-columns: 1fr;
      row-gap: 1.75rem;
    }
  }

  /* Shift Social and App columns right at desktop (mirrors lg:pl-8 in PLATAFORMA) */
  @media (min-width: 1025px) {
    .footer-columns .footer-column:nth-child(3),
    .footer-columns .footer-column:nth-child(4) {
      padding-left: 2rem;
    }
  }

  .footer-column h3.column-title {
    font-size: 0.7rem;
    font-weight: 800;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 1.25rem;
  }

  .footer-column ul {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 0;
    margin: 0;
    list-style: none;

    li {
      font-size: 0.875rem;
      color: var(--color-text-alt);
    }

    a {
      text-decoration: none;
      color: inherit;
      transition: color 0.2s var(--ease-out-cubic);

      &:hover {
        color: var(--color-cyan);
      }
    }
  }

  /* Contact icons */
  .contact-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;

    svg {
      flex-shrink: 0;
      margin-top: 0.15rem;
      color: var(--color-purple);
      opacity: 0.75;
    }

    a, span {
      flex: 1;
      line-height: 1.5;
    }
  }

  /* Social card */
  .social-list {
    gap: 0.625rem !important;

    .social-link {
      display: flex;
      width: 100%;
      align-items: center;
      gap: 0.75rem;
      padding: 0.875rem 1rem;
      border-radius: 0.75rem;
      background: var(--color-bg-alt);
      border: 1px solid rgba(var(--rgb-text), 0.06);
      color: var(--color-text-alt);
      font-size: 0.875rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.25s var(--ease-out-cubic);

      svg {
        flex-shrink: 0;
        transition: transform 0.25s var(--ease-out-cubic);
      }

      &:hover {
        transform: translateY(-2px);
        border-color: var(--color-cyan);
        color: var(--color-cyan);
        box-shadow: 0 4px 12px rgba(var(--rgb-cyan-accent), 0.15);

        svg {
          transform: scale(1.1);
        }
      }
    }
  }

  /* App download */
  .app-download {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;

    .version-tag {
      font-size: 0.75rem;
      color: var(--color-text-alt);
      font-weight: 500;
      letter-spacing: 0.02em;
    }

    .download-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.625rem 1rem;
      border-radius: 0.75rem;
      background: var(--color-purple);
      color: white;
      text-decoration: none;
      font-size: 0.875rem;
      font-weight: 600;
      transition: all 0.25s var(--ease-out-cubic);
      box-shadow: 0 6px 16px rgba(var(--rgb-purple-accent), 0.28);
      width: fit-content;

      svg {
        flex-shrink: 0;
        transition: transform 0.25s var(--ease-out-cubic);
      }

      &:hover {
        opacity: 0.88;
        transform: translateY(-2px);
        box-shadow: 0 10px 22px rgba(var(--rgb-purple-accent), 0.38);

        svg {
          transform: translateY(2px);
        }
      }

      &:active {
        transform: translateY(0);
      }
    }
  }

  /* Copyright */
  .cp {
    font-size: 0.75rem;
    text-align: center;
    color: var(--color-text-alt);
    opacity: 0.7;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(var(--rgb-text), 0.08);
    margin: 0;
    line-height: 1.5;
    padding-left: var(--container-offset);
    padding-right: var(--container-offset);

    @media (--mq-phone) {
      font-size: 0.6875rem;
    }
  }
</style>

<script>
  import { addResizeObserver } from "../utils/observers";

  class Footer extends HTMLElement {
    connectedCallback() {
      addResizeObserver(this);
      this.onResize();
    }

    onResize() {
      const inner = this.firstElementChild as HTMLElement;
      const bcr = inner.getBoundingClientRect();

      if (bcr.height + 100 > window.innerHeight) {
        this.style.height = "";
        this.classList.add("has-no-anim");
      } else {
        this.style.height = `${bcr.height}px`;
        this.classList.remove("has-no-anim");
      }
    }
  }

  customElements.define("sy-footer", Footer);
</script>
