---
import Layout from "../layouts/Layout.astro";
import HeroHome from "../components/HeroHome.astro";
import Faqs from "../components/Faqs.astro";

import VideoSection from "../components/VideoSection.astro";

import TechnologySection from "../components/TechnologySection.astro";
import { Testimonials } from "../components/Testimonials";
import { About } from "../components/About";
import ContactForm from "../components/ContactForm.astro";
import Statements from "../components/Statements.astro";
import EmpresaCTA from "../components/EmpresaCTA.astro";
import RegisterEmpresaModal from "../components/RegisterEmpresaModal.astro";
import { ui, defaultLang } from "../i18n/ui";
---

<Layout title={ui.es["nav.home"]}>
  <section id="inicio">
    <HeroHome
      lang="es"
      title={ui.es["hero.title"]}
      subtitle={ui.es["hero.subtitle"]}
      cta={{
        title: ui.es["hero.cta"],
        url: "#empresa",
      }}
    />
  </section>

  <div data-sy-reveal="fade">
    <VideoSection
      id="region"
      title={ui.es["video.title"]}
      description={ui.es["video.description"]}
      lang="es"
    />
  </div>

  <section id="tecnologia">
    <TechnologySection
      id="tecnologia-inner"
      lang="es"
      stats={[
        {
          number: ui.es["about.stat1.number"],
          suffix: ui.es["about.stat1.suffix"],
          label: ui.es["about.stat1.label"],
        },
        {
          number: ui.es["about.stat2.number"],
          suffix: ui.es["about.stat2.suffix"],
          label: ui.es["about.stat2.label"],
        },
        {
          number: ui.es["about.stat3.number"],
          suffix: ui.es["about.stat3.suffix"],
          label: ui.es["about.stat3.label"],
        },
      ]}
    />
  </section>

  <Statements
    items={[
      {
        title: ui.es["statement1.title"],
        text: ui.es["statement1.text"],
      },
      {
        title: ui.es["statement2.title"],
        text: ui.es["statement2.text"],
      },
      {
        title: ui.es["statement3.title"],
        text: ui.es["statement3.text"],
      },
    ]}
  />

  <div data-sy-reveal="fade">
    <About client:visible
      id="nosotros"
    title={ui.es["about.title"]}
    subtitle={ui.es["about.subtitle"]}
    sectionLabel={ui.es["about.sectionLabel"]}
    award={ui.es["about.award"]}
    awardBadge={ui.es["about.awardBadge"]}
    awardYear="2024"
    slides={[
      {
        id: "mission",
        label: ui.es["about.mission.title"],
        text: ui.es["about.mission.text"],
      },
      {
        id: "vision",
        label: ui.es["about.vision.title"],
        text: ui.es["about.vision.text"],
      },
      {
        id: "values",
        label: ui.es["about.values.title"],
        text: ui.es["about.values.text"],
      },
    ]}
    description={ui.es["about.description"]}
    timelineTitle={ui.es["timeline.title"]}
    timelineItems={[
      {
        title: ui.es["timeline.step1.title"],
        text: ui.es["timeline.step1.text"],
      },
      {
        title: ui.es["timeline.step2.title"],
        text: ui.es["timeline.step2.text"],
      },
      {
        title: ui.es["timeline.step3.title"],
        text: ui.es["timeline.step3.text"],
      },
      {
        title: ui.es["timeline.step4.title"],
        text: ui.es["timeline.step4.text"],
      },
    ]}
  />
  </div>

  {/* StepsTimeline moved to About */}

  <Testimonials client:visible
    title={ui.es["testimonials.title"]}
    testimonials={[
      {
        name: ui.es["testimonials.item1.name"],
        role: ui.es["testimonials.item1.role"],
        business: ui.es["testimonials.item1.business"],
        content: ui.es["testimonials.item1.content"],
      },
      {
        name: ui.es["testimonials.item2.name"],
        role: ui.es["testimonials.item2.role"],
        business: ui.es["testimonials.item2.business"],
        content: ui.es["testimonials.item2.content"],
      },
      {
        name: ui.es["testimonials.item3.name"],
        role: ui.es["testimonials.item3.role"],
        business: ui.es["testimonials.item3.business"],
        content: ui.es["testimonials.item3.content"],
      },
    ]}
  />

  <section id="empresa">
    <EmpresaCTA lang="es" />
  </section>

  {/* Sección de precios oculta temporalmente */}

  <section id="contacto">
    <ContactForm lang="es" />
    <Faqs
      title={ui.es["faqs.title"]}
      mobileTitle={ui.es["faqs.title"]}
      subtitle={ui.es["faqs.subtitle"]}
      items={[
        {
          question: ui.es["faq1.question"],
          answer: ui.es["faq1.answer"],
        },
        {
          question: ui.es["faq2.question"],
          answer: ui.es["faq2.answer"],
        },
        {
          question: ui.es["faq3.question"],
          answer: ui.es["faq3.answer"],
        },
        {
          question: ui.es["faq4.question"],
          answer: ui.es["faq4.answer"],
        },
        {
          question: ui.es["faq5.question"],
          answer: ui.es["faq5.answer"],
        },
      ]}
    />
  </section>

  <RegisterEmpresaModal />
</Layout>
