---
import { Font } from "astro:assets";
import Header from "../components/Header.astro";
import PageLoader from "../components/PageLoader.astro";
import Footer from "../components/Footer.astro";
import SmoothScroll from "../components/SmoothScroll.astro";
import { useTranslations, languages, defaultLang } from "../i18n/utils";
import { ui } from "../i18n/ui";
import "../styles/global.css";

const { title } = Astro.props;

// Detect language from URL path
const pathLang = Astro.url.pathname.split("/")[1];
const currentLang =
  pathLang && pathLang in languages
    ? (pathLang as keyof typeof ui)
    : defaultLang;
const t = useTranslations(currentLang);

// Localized navigation links
const linksMap = {
  es: [
    { title: t("nav.home"), url: "#inicio" },
    { title: t("nav.destination"), url: "#region" },
    { title: t("nav.technology"), url: "#tecnologia" },
    { title: t("nav.about"), url: "#nosotros" },
    { title: t("nav.pricing"), url: "#pricing" },
    { title: t("nav.contact"), url: "#contacto" },
  ],
  en: [
    { title: t("nav.home"), url: "#home" },
    { title: t("nav.destination"), url: "#region" },
    { title: t("nav.technology"), url: "#technology" },
    { title: t("nav.about"), url: "#about" },
    { title: t("nav.pricing"), url: "#pricing" },
    { title: t("nav.contact"), url: "#contact" },
  ],
  fr: [
    { title: t("nav.home"), url: "#home" },
    { title: t("nav.destination"), url: "#region" },
    { title: t("nav.technology"), url: "#technology" },
    { title: t("nav.about"), url: "#about" },
    { title: t("nav.pricing"), url: "#pricing" },
    { title: t("nav.contact"), url: "#contact" },
  ],
  pt: [
    { title: t("nav.home"), url: "#inicio" },
    { title: t("nav.destination"), url: "#region" },
    { title: t("nav.technology"), url: "#tecnologia" },
    { title: t("nav.about"), url: "#nosso" },
    { title: t("nav.pricing"), url: "#pricing" },
    { title: t("nav.contact"), url: "#contato" },
  ],
};

const links = linksMap[currentLang as keyof typeof linksMap] || linksMap.es;

// Localized SEO metadata
const seoMetadata = {
  es: {
    title: "SMARTUR | Turismo Inteligente en Veracruz — Altas Montañas",
    description:
      "Descubre qué hacer en Veracruz con SMARTUR. IA que recomienda hoteles, restaurantes y tours en Córdoba, Orizaba y las Altas Montañas. Turismo inteligente.",
    keywords:
      "qué hacer en Veracruz, turismo Veracruz, Altas Montañas Veracruz, turismo Córdoba Veracruz, recomendación turística, SMARTUR, rutas personalizadas Veracruz, inteligencia artificial turismo, hoteles Altas Montañas, restaurantes Córdoba, Orizaba turismo, MiPyMEs turísticas",
    ogTitle: "SMARTUR — Turismo Inteligente en las Altas Montañas de Veracruz",
    ogDescription:
      "Descubre qué hacer en Veracruz con SMARTUR. Recomendaciones con IA de hoteles, restaurantes y tours en Córdoba, Orizaba y la región.",
    locale: "es_MX",
  },
  en: {
    title: "SMARTUR | Smart Tourism in Veracruz — High Mountains",
    description:
      "Discover things to do in Veracruz with SMARTUR. AI-powered recommendations for hotels, restaurants, and tours in Córdoba, Orizaba and the Altas Montañas.",
    keywords:
      "things to do in Veracruz, Veracruz tourism, High Mountains Veracruz, Altas Montañas, Cordoba Veracruz tourism, SMARTUR, personalized travel recommendations, AI tourism Mexico, Orizaba tourism",
    ogTitle: "SMARTUR — Smart Tourism for the High Mountains of Veracruz",
    ogDescription:
      "Discover things to do in Veracruz with SMARTUR. AI-powered recommendations for hotels, restaurants, and tours in the High Mountains region.",
    locale: "en_US",
  },
  fr: {
    title: "SMARTUR | Tourisme Intelligent au Veracruz — Hautes Montagnes",
    description:
      "Découvrez quoi faire à Veracruz avec SMARTUR. Recommandations IA d'hôtels, restaurants et circuits dans les Hautes Montagnes, Córdoba et Orizaba.",
    keywords:
      "tourisme Veracruz, SMARTUR, IA touristique, Hautes Montagnes, recommandations personnalisées, PME touristiques, Veracruz Mexique",
    ogTitle: "SMARTUR — Tourisme Intelligent dans les Hautes Montagnes de Veracruz",
    ogDescription:
      "Découvrez quoi faire à Veracruz avec SMARTUR. Recommandations IA personnalisées dans les Hautes Montagnes.",
    locale: "fr_FR",
  },
  pt: {
    title: "SMARTUR | Turismo Inteligente no Veracruz — Altas Montanhas",
    description:
      "Descubra o que fazer em Veracruz com SMARTUR. IA que recomenda hotéis, restaurantes e tours em Córdoba, Orizaba e as Altas Montanhas do México.",
    keywords:
      "turismo Veracruz, SMARTUR, IA turística, Altas Montanhas, recomendações personalizadas, turismo Córdoba, Orizaba turismo, México",
    ogTitle: "SMARTUR — Turismo Inteligente nas Altas Montanhas de Veracruz",
    ogDescription:
      "Descubra o que fazer em Veracruz com SMARTUR. Recomendações IA personalizadas de hotéis, restaurantes e tours.",
    locale: "pt_BR",
  },
};

const seo = seoMetadata[currentLang];
const baseUrl = import.meta.env.PUBLIC_SITE_URL || "https://smartur.online";
const canonicalUrl = new URL(Astro.url.pathname, baseUrl).href;
---

<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="XkhhFJUQntUbRcnxirHrfxc9bwGFdOLx71tjWAHtwPk" />

    <!-- SMARTUR SEO Metadata -->
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta name="keywords" content={seo.keywords} />
    <meta name="author" content="SMARTUR" />
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- Hreflang / International SEO -->
    <link rel="alternate" hreflang="es" href={`${baseUrl}/`} />
    <link rel="alternate" hreflang="en" href={`${baseUrl}/en/`} />
    <link rel="alternate" hreflang="fr" href={`${baseUrl}/fr/`} />
    <link rel="alternate" hreflang="pt" href={`${baseUrl}/pt/`} />
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}/`} />

    <!-- Open Graph / Social Media -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SMARTUR" />
    <meta property="og:title" content={seo.ogTitle} />
    <meta property="og:description" content={seo.ogDescription} />
    <meta property="og:locale" content={seo.locale} />
    <meta property="og:image" content={`${baseUrl}/image-1.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:alt" content={seo.ogTitle} />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Fonts — preconnect + preload critical weights -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;900&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;900&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <!-- Cal Sans via CDN (fallback to system fonts if unavailable) -->
    <!-- <link href="https://fonts.cdnfonts.com/css/cal-sans" rel="stylesheet" /> -->

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t("layout.twitterCardTitle")} />
    <meta name="twitter:description" content={t("layout.twitterCardDesc")} />
    <meta name="twitter:image" content={`${baseUrl}/image-1.jpg`} />

    <!-- Favicon & Icon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "SMARTUR",
          "description": seo.description,
          "url": baseUrl,
          "logo": {
            "@type": "ImageObject",
            "url": `${baseUrl}/logo.png`,
            "width": 200,
            "height": 200
          },
          "address": {
            "@type": "PostalAddress",
            "addressRegion": "Veracruz",
            "addressCountry": "MX"
          },
          "contactPoint": {
            "@type": "ContactPoint",
            "email": "contacto@smartur.online",
            "contactType": "customer service",
            "availableLanguage": ["Spanish", "English"]
          },
          "sameAs": [
            "https://smartur.online",
            "https://instagram.com/smartur"
          ]
        },
        {
          "@type": "WebSite",
          "name": seo.title,
          "url": baseUrl,
          "description": seo.description,
          "inLanguage": currentLang,
          "potentialAction": {
            "@type": "SearchAction",
            "target": {
              "@type": "EntryPoint",
              "urlTemplate": `${baseUrl}/?q={search_term_string}`
            },
            "query-input": "required name=search_term_string"
          }
        },
        {
          "@type": "WebPage",
          "url": canonicalUrl,
          "name": `${title} | ${seo.title}`,
          "description": seo.description,
          "inLanguage": currentLang,
          "isPartOf": {
            "@type": "WebSite",
            "url": baseUrl
          }
        }
      ]
    })} />
  </head>
  <body class="is-loading" data-tab-away={t("tab.away")} data-tab-away-fallback={t("layout.tabAwayFallback")}>
    <PageLoader label={t("loader.ariaLabel")} />
    <div class="page-blobs" aria-hidden="true">
      <div class="pblob pblob-cyan-tr"></div>
      <div class="pblob pblob-pink-ml"></div>
      <div class="pblob pblob-purple-mr"></div>
      <div class="pblob pblob-cyan-bl"></div>
      <div class="pblob pblob-pink-br"></div>
      <div class="pblob pblob-purple-bc"></div>
    </div>
    <Header
      logoUrl="/"
      logoAlt={t("header.logo.alt")}
      links={links}
      link1={{ title: t("button.login"), url: import.meta.env.PUBLIC_TOURIST_APP_URL || "https://app.smartur.online/" }}
      link2={{ title: t("button.get-started"), url: "#contacto" }}
      mobileMenuLabel={t("accessibility.toggleMenu")}
    />
    <div id="smooth-wrapper">
      <div id="smooth-content">
        <main id="main">
          <slot />
        </main>
        <Footer
          lang={currentLang}
          logoUrl="/"
          logoAlt="SMARTUR"
          links={links}
          slogan={t("footer.slogan")}
          description={t("footer.description")}
          quickLinksTitle={t("footer.quicklinks")}
          contactTitle={t("footer.contact")}
          socialTitle={t("footer.social")}
          mobileAppTitle={t("footer.mobileApp")}
          mobileAppDownload={t("footer.mobileApp.download")}
          mobileAppVersion={t("footer.mobileApp.version")}
          copyright={t("footer.copyright")}
          address={t("footer.address")}
        />
      </div>
    </div>
    <SmoothScroll />
  </body>
</html>

<style>
  body.is-loading {
    overflow: hidden;
  }

  .skip-link {
    background: var(--color-brand-1);
    left: 0;
    right: 0;
    margin: auto;
    width: min-content;
    white-space: nowrap;
    padding: 0.5rem;
    position: absolute;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    z-index: 100;
  }

  .skip-link:focus {
    transform: translateY(0%);
  }

  /* GSAP ScrollSmoother (desktop only); native scroll on mobile/tablet for fluidity */
  #smooth-wrapper {
    overflow: hidden;
    position: fixed;
    height: 100%;
    width: 100%;
    top: 0;
    left: 0;
  }

  #smooth-content {
    overflow: visible;
    width: 100%;
    position: relative;
  }

  body.native-scroll #smooth-wrapper {
    position: static;
    height: auto;
    min-height: 100%;
    overflow: visible;
  }

  body.native-scroll #smooth-content {
    min-height: 100%;
    padding-bottom: 10rem; /* space so fixed footer does not cover content */
  }

  @media (--mq-phone) {
    body.native-scroll #smooth-content {
      padding-bottom: 6rem;
    }
  }
</style>

<script>
  import "../utils/reveals";

  // Tab visibility effect
  (() => {
    const originalTitle = document.title;
    const tabAwayMessage =
      document.body.dataset.tabAway || document.body.dataset.tabAwayFallback;
    document.addEventListener("visibilitychange", () => {
      document.title = document.hidden ? tabAwayMessage : originalTitle;
    });
  })();

  // Developer console easter egg
  (() => {
    const c = (color: string) => `color:${color};font-weight:700;font-size:13px`;
    console.log(
      "%cSMARTUR%c  Turismo Inteligente · Altas Montañas de Veracruz\n%c¿Te gusta lo que ves? Hablemos: martinlaraolivares@gmail.com",
      `${c('#4DB9CA')};font-size:20px`,
      c('#984EFD'),
      `color:#aaa;font-weight:400;font-size:11px`
    );
  })();
</script>
