---
import { Font } from "astro:assets";
import Header from "../components/Header.astro";
import PageLoader from "../components/PageLoader.astro";
import Footer from "../components/Footer.astro";
import SmoothScroll from "../components/SmoothScroll.astro";
import { useTranslations, languages, defaultLang } from "../i18n/utils";
import { ui } from "../i18n/ui";
import "../styles/global.css";

const { title } = Astro.props;

// Detect language from URL path
const pathLang = Astro.url.pathname.split("/")[1];
const currentLang =
  pathLang && pathLang in languages
    ? (pathLang as keyof typeof ui)
    : defaultLang;
const t = useTranslations(currentLang);

// Localized navigation links
const linksMap = {
  es: [
    { title: t("nav.home"), url: "#inicio" },
    { title: t("nav.destination"), url: "#region" },
    { title: t("nav.technology"), url: "#tecnologia" },
    { title: t("nav.about"), url: "#nosotros" },
    { title: t("nav.pricing"), url: "#pricing" },
    { title: t("nav.contact"), url: "#contacto" },
  ],
  en: [
    { title: t("nav.home"), url: "#home" },
    { title: t("nav.destination"), url: "#region" },
    { title: t("nav.technology"), url: "#technology" },
    { title: t("nav.about"), url: "#about" },
    { title: t("nav.pricing"), url: "#pricing" },
    { title: t("nav.contact"), url: "#contact" },
  ],
  fr: [
    { title: t("nav.home"), url: "#home" },
    { title: t("nav.destination"), url: "#region" },
    { title: t("nav.technology"), url: "#technology" },
    { title: t("nav.about"), url: "#about" },
    { title: t("nav.pricing"), url: "#pricing" },
    { title: t("nav.contact"), url: "#contact" },
  ],
  pt: [
    { title: t("nav.home"), url: "#inicio" },
    { title: t("nav.destination"), url: "#region" },
    { title: t("nav.technology"), url: "#tecnologia" },
    { title: t("nav.about"), url: "#nosso" },
    { title: t("nav.pricing"), url: "#pricing" },
    { title: t("nav.contact"), url: "#contato" },
  ],
};

const links = linksMap[currentLang as keyof typeof linksMap] || linksMap.es;

// Localized SEO metadata
const seoMetadata = {
  es: {
    title: "SMARTUR - Turismo Inteligente en las Altas Montañas",
    description:
      "SMARTUR: Plataforma de recomendación turística inteligente para MiPyMEs en las Altas Montañas de Veracruz. Utilizamos IA para potenciar el turismo regional con recomendaciones personalizadas.",
    keywords:
      "Turismo Veracruz, SMARTUR, IA Turística, Altas Montañas, Recomendaciones Personalizadas, MiPyMEs Turísticas, Inteligencia Artificial, Turismo Regional, Machine Learning, Veracruz México",
    ogTitle: "SMARTUR - Turismo Inteligente en las Altas Montañas de Veracruz",
    ogDescription:
      "Plataforma de IA para recomendaciones turísticas personalizadas en la región de Las Altas Montañas, Veracruz",
    locale: "es_MX",
  },
  en: {
    title: "SMARTUR - Smart Tourism for the High Mountains",
    description:
      "SMARTUR: Intelligent tourism recommendation platform for SMEs in the High Mountains of Veracruz. We use AI to boost regional tourism with personalized recommendations.",
    keywords:
      "Veracruz Tourism, SMARTUR, Tourism AI, High Mountains, Personalized Recommendations, Tourism SMEs, Artificial Intelligence, Regional Tourism, Machine Learning, Veracruz Mexico",
    ogTitle: "SMARTUR - Smart Tourism for the High Mountains of Veracruz",
    ogDescription:
      "AI platform for personalized tourism recommendations in the High Mountains region, Veracruz",
    locale: "en_US",
  },
  fr: {
    title: "SMARTUR - Tourisme Intelligent pour les Hautes Montagnes",
    description:
      "SMARTUR: Plateforme de recommandation touristique intelligente pour les PME dans les Hautes Montagnes de Veracruz. Nous utilisons l'IA pour stimuler le tourisme régional avec des recommandations personnalisées.",
    keywords:
      "Tourisme Veracruz, SMARTUR, IA Touristique, Hautes Montagnes, Recommandations Personnalisées, PME Touristiques, Intelligence Artificielle, Tourisme Régional, Machine Learning, Veracruz Mexique",
    ogTitle:
      "SMARTUR - Tourisme Intelligent pour les Hautes Montagnes de Veracruz",
    ogDescription:
      "Plateforme d'IA pour des recommandations touristiques personnalisées dans la région des Hautes Montagnes, Veracruz",
    locale: "fr_FR",
  },
  pt: {
    title: "SMARTUR - Turismo Inteligente nas Altas Montanhas",
    description:
      "SMARTUR: Plataforma de recomendação turística inteligente para MiPyMEs nas Altas Montanhas de Veracruz. Usamos IA para potencializar o turismo regional com recomendações personalizadas.",
    keywords:
      "Turismo Veracruz, SMARTUR, IA Turística, Altas Montanhas, Recomendações Personalizadas, MiPyMEs Turísticas, Inteligência Artificial, Turismo Regional, Machine Learning, Veracruz México",
    ogTitle: "SMARTUR - Turismo Inteligente nas Altas Montanhas de Veracruz",
    ogDescription:
      "Plataforma de IA para recomendações turísticas personalizadas na região das Altas Montanhas, Veracruz",
    locale: "pt_BR",
  },
};

const seo = seoMetadata[currentLang];
---

<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="XkhhFJUQntUbRcnxirHrfxc9bwGFdOLx71tjWAHtwPk" />

    <!-- SMARTUR SEO Metadata -->
    <title>{title} | {seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta name="keywords" content={seo.keywords} />
    <meta name="author" content="SMARTUR" />

    <!-- Open Graph / Social Media -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={seo.ogTitle} />
    <meta property="og:description" content={seo.ogDescription} />
    <meta property="og:locale" content={seo.locale} />
    <meta property="og:image" content={`${import.meta.env.PUBLIC_SITE_URL || 'https://smartur.online'}/image-1.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={seo.ogTitle} />
    <meta property="og:url" content={import.meta.env.PUBLIC_SITE_URL || 'https://smartur.online'} />

    <!-- Fonts - Vibrant Design System -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <!-- Cal Sans via CDN (fallback to system fonts if unavailable) -->
    <!-- <link href="https://fonts.cdnfonts.com/css/cal-sans" rel="stylesheet" /> -->

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t("layout.twitterCardTitle")} />
    <meta name="twitter:description" content={t("layout.twitterCardDesc")} />
    <meta name="twitter:image" content={`${import.meta.env.PUBLIC_SITE_URL || 'https://smartur.online'}/image-1.jpg`} />

    <!-- Favicon & Icon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="canonical" href={import.meta.env.PUBLIC_SITE_URL || 'https://smartur.online'} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "SMARTUR",
      "description": seo.description,
      "url": import.meta.env.PUBLIC_SITE_URL || "https://smartur.online",
      "logo": {
        "@type": "ImageObject",
        "url": `${import.meta.env.PUBLIC_SITE_URL || "https://smartur.online"}/logo.png`,
        "width": 200,
        "height": 200
      },
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "Veracruz",
        "addressCountry": "MX"
      },
      "sameAs": ["https://smartur.online"]
    })} />
  </head>
  <body class="is-loading" data-tab-away={t("tab.away")} data-tab-away-fallback={t("layout.tabAwayFallback")}>
    <PageLoader label={t("loader.ariaLabel")} />
    <div class="page-blobs" aria-hidden="true">
      <div class="pblob pblob-cyan-tr"></div>
      <div class="pblob pblob-pink-ml"></div>
      <div class="pblob pblob-purple-mr"></div>
      <div class="pblob pblob-cyan-bl"></div>
      <div class="pblob pblob-pink-br"></div>
      <div class="pblob pblob-purple-bc"></div>
    </div>
    <a href="#main" class="skip-link">{t("accessibility.skip-to-content")}</a>
    <Header
      logoUrl="/"
      logoAlt={t("header.logo.alt")}
      links={links}
      link1={{ title: t("button.login"), url: import.meta.env.PUBLIC_TOURIST_APP_URL || "https://app.smartur.online/" }}
      link2={{ title: t("button.get-started"), url: "#contacto" }}
      mobileMenuLabel={t("accessibility.toggleMenu")}
    />
    <div id="smooth-wrapper">
      <div id="smooth-content">
        <main id="main">
          <slot />
        </main>
        <Footer
          lang={currentLang}
          logoUrl="/"
          logoAlt="SMARTUR"
          links={links}
          slogan={t("footer.slogan")}
          description={t("footer.description")}
          quickLinksTitle={t("footer.quicklinks")}
          contactTitle={t("footer.contact")}
          socialTitle={t("footer.social")}
          mobileAppTitle={t("footer.mobileApp")}
          mobileAppDownload={t("footer.mobileApp.download")}
          mobileAppVersion={t("footer.mobileApp.version")}
          copyright={t("footer.copyright")}
          address={t("footer.address")}
        />
      </div>
    </div>
    <SmoothScroll />
  </body>
</html>

<style>
  body.is-loading {
    overflow: hidden;
  }

  .skip-link {
    background: var(--color-brand-1);
    left: 0;
    right: 0;
    margin: auto;
    width: min-content;
    white-space: nowrap;
    padding: 0.5rem;
    position: absolute;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    z-index: 100;
  }

  .skip-link:focus {
    transform: translateY(0%);
  }

  /* GSAP ScrollSmoother (desktop only); native scroll on mobile/tablet for fluidity */
  #smooth-wrapper {
    overflow: hidden;
    position: fixed;
    height: 100%;
    width: 100%;
    top: 0;
    left: 0;
  }

  #smooth-content {
    overflow: visible;
    width: 100%;
    position: relative;
  }

  body.native-scroll #smooth-wrapper {
    position: static;
    height: auto;
    min-height: 100%;
    overflow: visible;
  }

  body.native-scroll #smooth-content {
    min-height: 100%;
    padding-bottom: 10rem; /* space so fixed footer does not cover content */
  }

  @media (--mq-phone) {
    body.native-scroll #smooth-content {
      padding-bottom: 6rem;
    }
  }
</style>

<script>
  import "../utils/reveals";

  // Tab visibility effect - change title when user leaves
  (() => {
    const originalTitle = document.title;
    const tabAwayMessage =
      document.body.dataset.tabAway || document.body.dataset.tabAwayFallback;

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        document.title = tabAwayMessage;
      } else {
        document.title = originalTitle;
      }
    });
  })();
</script>
