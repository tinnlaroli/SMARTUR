# ── MODELO — Variables de entorno ───────────────────────────────────────────
# Copia este archivo a .env y ajusta los valores.

# ── Base de datos PostgreSQL ─────────────────────────────────────────────────
POI_DB_HOST=localhost
POI_DB_PORT=5432
POI_DB_NAME=smartur
POI_DB_USER=postgres
POI_DB_PASSWORD=your_db_password

# Alias alternativos (usados en algunos endpoints)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartur
DB_USER=postgres
DB_PASSWORD=your_db_password

# ── Comportamiento del modelo ────────────────────────────────────────────────
# Poner en 1 para saltar la carga de modelos al arrancar (útil en CI o dev rápido)
SKIP_MODEL_BOOT=0

# Poner en 1 para entrenar automáticamente si no hay modelos guardados
AUTO_BOOTSTRAP=1

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Datos de entrenamiento (Kaggle — opcional) ───────────────────────────────
# Solo necesario si se usa Kaggle para descargar datasets adicionales
KAGGLE_USERNAME=
KAGGLE_KEY=
